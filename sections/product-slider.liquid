<style>
.pet-ps-{{ section.id }} {
  --pet-primary: {{ section.settings.primary_color }};
  --pet-primary-light: {{ section.settings.primary_light_color }};
  --pet-primary-deep: {{ section.settings.primary_deep_color }};
  --pet-bg: {{ section.settings.bg_color }};
  --pet-card: #FFFFFF;
  --pet-image-bg: {{ section.settings.image_bg }};
  --pet-ink: #1F1342;
  --pet-body: #5A4F75;
  --pet-mute: #8B8299;
  --pet-line: rgba(123, 63, 242, 0.10);

  background-color: var(--pet-bg);
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  font-family: inherit, 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  overflow: hidden;
}

.pet-ps-{{ section.id }} *,
.pet-ps-{{ section.id }} *::before,
.pet-ps-{{ section.id }} *::after {
  box-sizing: border-box;
}

.pet-ps-container-{{ section.id }} {
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: 0 16px;
}

/* ===== HEADER ===== */
.pet-ps-header-{{ section.id }} {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  gap: 16px;
}

.pet-ps-title-{{ section.id }} {
  font-family: inherit;
  font-size: clamp(20px, 2.6vw, {{ section.settings.title_size }}px);
  font-weight: 800;
  color: var(--pet-ink);
  margin: 0;
  letter-spacing: -0.025em;
  line-height: 1.15;
}

.pet-ps-actions-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.pet-ps-nav-{{ section.id }} {
  display: flex;
  gap: 6px;
}

.pet-ps-nav-btn-{{ section.id }} {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: var(--pet-card);
  border: 1px solid var(--pet-line);
  color: var(--pet-ink);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
  padding: 0;
}

.pet-ps-nav-btn-{{ section.id }} svg {
  width: 14px;
  height: 14px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.pet-ps-nav-btn-{{ section.id }}:hover:not(:disabled) {
  background: var(--pet-primary);
  border-color: var(--pet-primary);
  color: #FFFFFF;
}

.pet-ps-nav-btn-{{ section.id }}:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.pet-ps-view-all-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: var(--pet-primary);
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  transition: gap 0.2s ease;
  white-space: nowrap;
}

.pet-ps-view-all-{{ section.id }}:hover {
  gap: 8px;
  color: var(--pet-primary-deep);
}

.pet-ps-view-all-{{ section.id }} svg {
  width: 14px;
  height: 14px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* ===== SLIDER TRACK ===== */
.pet-ps-track-wrapper-{{ section.id }} {
  position: relative;
  margin: 0 -16px;
  padding: 0 16px;
}

.pet-ps-track-{{ section.id }} {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scrollbar-width: none;
  padding: 4px 0 16px;
  -webkit-overflow-scrolling: touch;
}

.pet-ps-track-{{ section.id }}::-webkit-scrollbar {
  display: none;
}

.pet-ps-slide-{{ section.id }} {
  flex: 0 0 calc((100% - 36px) / 4);
  scroll-snap-align: start;
  min-width: 0;
}

/* User's product-card snippet hover */
.pet-ps-slide-{{ section.id }} .forspaceon-pc-card {
  transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.25s ease, border-color 0.25s ease;
}
.pet-ps-slide-{{ section.id }} .forspaceon-pc-card:hover {
  border-color: var(--pet-primary-light);
  box-shadow: 0 12px 24px -14px rgba(123, 63, 242, 0.22);
  transform: translateY(-2px);
}

/* ===== MINIMAL CARD (collection seçilmediğinde — Getir tarzı) ===== */
.pet-ps-card-{{ section.id }} {
  background: var(--pet-card);
  border-radius: 14px;
  overflow: hidden;
  height: 100%;
  display: flex;
  flex-direction: column;
  transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.25s ease;
  position: relative;
}

.pet-ps-card-{{ section.id }}:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 24px -14px rgba(123, 63, 242, 0.22);
}

.pet-ps-card-image-{{ section.id }} {
  position: relative;
  aspect-ratio: 1 / 1;
  background: var(--pet-image-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14px;
  overflow: hidden;
}

.pet-ps-card-image-{{ section.id }} svg.pet-illust {
  width: 50%;
  height: 50%;
  color: var(--pet-primary);
  opacity: 0.4;
}

.pet-ps-tag-{{ section.id }} {
  position: absolute;
  top: 8px;
  left: 8px;
  background: var(--pet-card);
  color: var(--pet-primary);
  padding: 3px 8px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  border-radius: 100px;
  box-shadow: 0 2px 6px -2px rgba(31, 19, 66, 0.10);
}

.pet-ps-cart-btn-{{ section.id }} {
  position: absolute;
  bottom: 8px;
  right: 8px;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--pet-primary);
  color: #FFFFFF;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 10px -3px rgba(123, 63, 242, 0.5);
  transition: transform 0.18s ease, background-color 0.18s ease;
  padding: 0;
}

.pet-ps-cart-btn-{{ section.id }}:hover {
  transform: scale(1.08);
  background: var(--pet-primary-deep);
}

.pet-ps-cart-btn-{{ section.id }} svg {
  width: 14px;
  height: 14px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.pet-ps-card-info-{{ section.id }} {
  padding: 10px 4px 4px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.pet-ps-price-row-{{ section.id }} {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.pet-ps-price-{{ section.id }} {
  font-size: 15px;
  font-weight: 800;
  color: var(--pet-ink);
  letter-spacing: -0.02em;
}

.pet-ps-price-old-{{ section.id }} {
  font-size: 12px;
  color: var(--pet-mute);
  text-decoration: line-through;
  font-weight: 500;
}

.pet-ps-name-{{ section.id }} {
  font-size: 13px;
  font-weight: 500;
  color: var(--pet-body);
  margin: 2px 0 0 0;
  line-height: 1.3;
  letter-spacing: -0.005em;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.pet-ps-variant-{{ section.id }} {
  font-size: 11px;
  color: var(--pet-mute);
  font-weight: 500;
  margin-top: 2px;
}

/* ===== PAGINATION (mobile only) ===== */
.pet-ps-pagination-{{ section.id }} {
  display: none;
  justify-content: center;
  align-items: center;
  gap: 6px;
  margin-top: 14px;
}

.pet-ps-dot-{{ section.id }} {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: rgba(123, 63, 242, 0.18);
  transition: all 0.3s ease;
  display: inline-block;
}

.pet-ps-dot-{{ section.id }}.is-active {
  background-color: var(--pet-primary);
  width: 18px;
  border-radius: 6px;
}

/* ===== TABLET (≤1024px) — 3 kart ===== */
@media screen and (max-width: 1024px) {
  .pet-ps-slide-{{ section.id }} {
    flex: 0 0 calc((100% - 24px) / 3);
  }
}

/* ===== MOBİL TABLET ARASI (≤768px) — kompakt ===== */
@media screen and (max-width: 768px) {
  .pet-ps-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.65 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round }}px;
  }

  .pet-ps-header-{{ section.id }} {
    margin-bottom: 14px;
  }

  .pet-ps-nav-{{ section.id }} {
    display: none;
  }

  /* 2.3 kart görünür — kullanıcı sağda kart hint görür */
  .pet-ps-slide-{{ section.id }} {
    flex: 0 0 calc((100% - 24px) / 2.3);
  }

  .pet-ps-track-{{ section.id }} {
    gap: 10px;
    padding-right: 16px;
  }

  .pet-ps-pagination-{{ section.id }} {
    display: flex;
  }
}

/* ===== KÜÇÜK MOBİL (≤420px) — daha kompakt ===== */
@media screen and (max-width: 420px) {
  .pet-ps-{{ section.id }} {
    padding-top: 24px;
    padding-bottom: 24px;
  }

  .pet-ps-container-{{ section.id }} {
    padding: 0 12px;
  }

  .pet-ps-track-wrapper-{{ section.id }} {
    margin: 0 -12px;
    padding: 0 12px;
  }

  /* 2.2 kart, biraz daha sıkı */
  .pet-ps-slide-{{ section.id }} {
    flex: 0 0 calc((100% - 20px) / 2.2);
  }

  .pet-ps-track-{{ section.id }} {
    gap: 9px;
    padding-right: 12px;
  }

  .pet-ps-tag-{{ section.id }} {
    top: 6px;
    left: 6px;
    font-size: 9px;
    padding: 2px 7px;
  }

  .pet-ps-cart-btn-{{ section.id }} {
    width: 28px;
    height: 28px;
    bottom: 6px;
    right: 6px;
  }
  .pet-ps-cart-btn-{{ section.id }} svg {
    width: 12px;
    height: 12px;
  }

  .pet-ps-card-info-{{ section.id }} {
    padding: 8px 2px 2px;
  }

  .pet-ps-price-{{ section.id }} {
    font-size: 14px;
  }
  .pet-ps-price-old-{{ section.id }} {
    font-size: 11px;
  }
  .pet-ps-name-{{ section.id }} {
    font-size: 12px;
  }
  .pet-ps-variant-{{ section.id }} {
    font-size: 10px;
  }

  .pet-ps-view-all-{{ section.id }} {
    font-size: 13px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .pet-ps-track-{{ section.id }} {
    scroll-behavior: auto;
  }
  .pet-ps-card-{{ section.id }},
  .pet-ps-slide-{{ section.id }} .forspaceon-pc-card {
    transition: none !important;
  }
}
</style>

<section class="pet-ps-{{ section.id }}">
  <div class="pet-ps-container-{{ section.id }}">

    <div class="pet-ps-header-{{ section.id }}">
      <h2 class="pet-ps-title-{{ section.id }}">{{ section.settings.title }}</h2>

      <div class="pet-ps-actions-{{ section.id }}">
        {% if section.settings.show_nav_buttons %}
          <div class="pet-ps-nav-{{ section.id }}">
            <button type="button" class="pet-ps-nav-btn-{{ section.id }}" data-direction="prev" aria-label="Önceki">
              <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button type="button" class="pet-ps-nav-btn-{{ section.id }}" data-direction="next" aria-label="Sonraki">
              <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        {% endif %}

        {% if section.settings.btn_label != blank %}
          <a href="{{ section.settings.collection.url | default: '#' }}" class="pet-ps-view-all-{{ section.id }}">
            {{ section.settings.btn_label }}
            <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <div class="pet-ps-track-wrapper-{{ section.id }}">
      <div class="pet-ps-track-{{ section.id }}" id="Slider-{{ section.id }}">
        {% if section.settings.collection != blank and section.settings.collection.products_count > 0 %}
          {% for product in section.settings.collection.products limit: section.settings.limit %}
            <div class="pet-ps-slide-{{ section.id }}">
              {% render 'product-card', product: product %}
            </div>
          {% endfor %}
        {% else %}
          {%- comment -%} 12 demo ürün — Getir tarzı minimal {%- endcomment -%}
          {% assign demo_products = "Premium Tahılsız Kedi Maması@Royal Canin@1.5 KG@450@600@İndirim,Doğal Kedi Otu Oyuncağı@PetSafe@2 Adet@89@129@,Ortopedik Köpek Yatağı L@Comfy Pet@70x90 cm@699@899@Çok Satan,Multivitamin Damla@VitaPet@30 ml@245@320@,Otomatik Mama Kabı@SmartFeed@2 L@1299@1599@Yeni,Tüy Bakım Fırçası@FurEase@Standart@129@169@,Eğitim Tasması@TrainPro@M Beden@349@429@,Doğal Köpek Bisküvisi@BarkBakery@500 G@79@99@İndirim,Kedi Tırmalama Tahtası@ScratchPlus@45 cm@189@@,Yavru Köpek Maması@Hill's@2 KG@520@@Yeni,Kedi Kumu Topaklanan@Petlife@10 L@159@199@,Köpek Şampuanı@CleanPaws@500 ml@95@@" | split: "," %}
          {% for demo in demo_products %}
            {% assign parts = demo | split: "@" %}
            <div class="pet-ps-slide-{{ section.id }}">
              <div class="pet-ps-card-{{ section.id }}">
                <div class="pet-ps-card-image-{{ section.id }}">
                  {% if parts[5] != blank %}
                    <span class="pet-ps-tag-{{ section.id }}">{{ parts[5] }}</span>
                  {% endif %}
                  <svg class="pet-illust" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="4" r="2"/>
                    <circle cx="18" cy="8" r="2"/>
                    <circle cx="20" cy="16" r="2"/>
                    <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/>
                  </svg>
                  <button type="button" class="pet-ps-cart-btn-{{ section.id }}" aria-label="Sepete Ekle">
                    <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
                  </button>
                </div>
                <div class="pet-ps-card-info-{{ section.id }}">
                  <div class="pet-ps-price-row-{{ section.id }}">
                    <span class="pet-ps-price-{{ section.id }}">{{ parts[3] }}₺</span>
                    {% if parts[4] != blank %}
                      <span class="pet-ps-price-old-{{ section.id }}">{{ parts[4] }}₺</span>
                    {% endif %}
                  </div>
                  <h3 class="pet-ps-name-{{ section.id }}">{{ parts[0] }}</h3>
                  {% if parts[2] != blank %}
                    <span class="pet-ps-variant-{{ section.id }}">{{ parts[2] }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    {% if section.settings.show_pagination %}
      <div class="pet-ps-pagination-{{ section.id }}">
        <span class="pet-ps-dot-{{ section.id }} is-active"></span>
        <span class="pet-ps-dot-{{ section.id }}"></span>
        <span class="pet-ps-dot-{{ section.id }}"></span>
      </div>
    {% endif %}

  </div>
</section>

<script>
(function() {
  var track = document.getElementById('Slider-{{ section.id }}');
  if (!track) return;

  var navBtns = document.querySelectorAll('.pet-ps-nav-btn-{{ section.id }}');
  var dots = document.querySelectorAll('.pet-ps-pagination-{{ section.id }} .pet-ps-dot-{{ section.id }}');

  function getScrollAmount() {
    var slide = track.querySelector('.pet-ps-slide-{{ section.id }}');
    if (!slide) return track.clientWidth * 0.8;
    var styles = window.getComputedStyle(track);
    var gap = parseFloat(styles.gap || styles.columnGap || '12');
    return slide.offsetWidth + gap;
  }

  function maxScroll() {
    return track.scrollWidth - track.clientWidth;
  }

  function updateButtons() {
    var max = maxScroll();
    navBtns.forEach(function(btn) {
      var dir = btn.getAttribute('data-direction');
      if (max <= 0) {
        btn.disabled = true;
        return;
      }
      if (dir === 'prev') {
        btn.disabled = track.scrollLeft <= 1;
      } else {
        btn.disabled = track.scrollLeft >= max - 1;
      }
    });
  }

  function updateDots() {
    if (dots.length !== 3) return;
    var max = maxScroll();
    if (max <= 0) {
      dots.forEach(function(d, i) { d.classList.toggle('is-active', i === 0); });
      return;
    }
    var percent = track.scrollLeft / max;
    if (percent < 0) percent = 0;
    if (percent > 1) percent = 1;
    var activeIndex = percent < 0.34 ? 0 : (percent < 0.67 ? 1 : 2);
    dots.forEach(function(d, i) { d.classList.toggle('is-active', i === activeIndex); });
  }

  navBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var dir = btn.getAttribute('data-direction');
      var amount = getScrollAmount();
      track.scrollBy({ left: dir === 'prev' ? -amount : amount, behavior: 'smooth' });
    });
  });

  var ticking = false;
  track.addEventListener('scroll', function() {
    if (!ticking) {
      window.requestAnimationFrame(function() {
        updateButtons();
        updateDots();
        ticking = false;
      });
      ticking = true;
    }
  });

  window.addEventListener('resize', function() {
    updateButtons();
    updateDots();
  });

  updateButtons();
  updateDots();
})();
</script>

{% schema %}
{
  "name": "Pet Product Slider",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "image_bg",
      "label": "Card Image Background",
      "info": "Ürün görselinin arkasındaki soft renk",
      "default": "#F6F2FF"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color (Mor)",
      "default": "#7B3FF2"
    },
    {
      "type": "color",
      "id": "primary_light_color",
      "label": "Açık Mor",
      "default": "#B794F4"
    },
    {
      "type": "color",
      "id": "primary_deep_color",
      "label": "Koyu Mor",
      "default": "#5B2FB2"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Çok Satanlar"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Title Max Size (Desktop)",
      "default": 28
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "View All Button Label",
      "default": "Tümünü Gör"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 24,
      "step": 1,
      "label": "Maximum Products",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_nav_buttons",
      "label": "Prev/Next Butonları (Desktop)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Mobile Dots (Paginasyon)",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1300
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Pet Product Slider"
    }
  ]
}
{% endschema %}
